{
  "name": "@eresearchqut/schema-store",
  "version": "1.7.4",
  "description": "A TypeScript library providing a generic validation and store operations for json schemas.",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "module": "./dist/index.mjs",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsdown",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "jest": "^30.4.2",
    "semantic-release": "^25.0.3",
    "ts-jest": "^29.4.10",
    "ts-node": "^10.9.2",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  },
  "peerDependencies": {
    "json-schema-library": "^11.4.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eresearchqut/schema-store.git"
  }
}
